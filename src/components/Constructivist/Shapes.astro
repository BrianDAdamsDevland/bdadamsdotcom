---
/* Reusable constructivist SVG shapes. Pass a `variant` to pick a composition. */
interface Props {
  variant?: "wedge" | "circles" | "stack" | "register" | "compass";
  class?: string;
  flip?: boolean;
}

const { variant = "wedge", class: className = "", flip = false } = Astro.props;
---

{variant === "wedge" && (
  <svg
    class={`con-shape con-shape--wedge ${className}`}
    viewBox="0 0 200 200"
    xmlns="http://www.w3.org/2000/svg"
    role="presentation"
    aria-hidden="true"
    style={flip ? "transform: scaleX(-1);" : ""}
  >
    <polygon points="0,200 200,0 200,200" fill="var(--con-orange)" />
    <circle cx="160" cy="40" r="22" fill="var(--con-black)" />
    <line x1="0" y1="200" x2="200" y2="0" stroke="var(--con-black)" stroke-width="3" />
  </svg>
)}

{variant === "circles" && (
  <svg
    class={`con-shape con-shape--circles ${className}`}
    viewBox="0 0 200 200"
    xmlns="http://www.w3.org/2000/svg"
    role="presentation"
    aria-hidden="true"
  >
    <circle cx="100" cy="100" r="90" fill="var(--con-black)" />
    <circle cx="100" cy="100" r="60" fill="var(--con-orange)" />
    <circle cx="100" cy="100" r="30" fill="var(--con-cream)" />
    <line x1="100" y1="0" x2="100" y2="200" stroke="var(--con-cream)" stroke-width="2" />
  </svg>
)}

{variant === "stack" && (
  <svg
    class={`con-shape con-shape--stack ${className}`}
    viewBox="0 0 200 200"
    xmlns="http://www.w3.org/2000/svg"
    role="presentation"
    aria-hidden="true"
  >
    <rect x="20" y="20" width="160" height="20" fill="var(--con-black)" />
    <rect x="20" y="50" width="120" height="20" fill="var(--con-orange)" />
    <rect x="20" y="80" width="160" height="20" fill="var(--con-black)" />
    <rect x="20" y="110" width="80" height="20" fill="var(--con-yellow)" />
    <rect x="20" y="140" width="160" height="20" fill="var(--con-black)" />
    <rect x="20" y="170" width="100" height="20" fill="var(--con-orange)" />
  </svg>
)}

{variant === "register" && (
  <svg
    class={`con-shape con-shape--register ${className}`}
    viewBox="0 0 200 60"
    xmlns="http://www.w3.org/2000/svg"
    role="presentation"
    aria-hidden="true"
    preserveAspectRatio="none"
  >
    <rect x="0" y="20" width="200" height="6" fill="var(--con-black)" />
    <circle cx="20" cy="23" r="9" fill="var(--con-orange)" stroke="var(--con-black)" stroke-width="2" />
    <rect x="50" y="14" width="14" height="18" fill="var(--con-black)" />
    <polygon points="80,32 95,14 110,32" fill="var(--con-yellow)" stroke="var(--con-black)" stroke-width="2" />
    <rect x="130" y="14" width="60" height="18" fill="none" stroke="var(--con-black)" stroke-width="2" />
    <rect x="130" y="14" width="30" height="18" fill="var(--con-orange)" />
  </svg>
)}

{variant === "compass" && (
  <svg
    class={`con-shape con-shape--compass ${className}`}
    viewBox="0 0 220 220"
    xmlns="http://www.w3.org/2000/svg"
    role="presentation"
    aria-hidden="true"
  >
    <circle cx="110" cy="110" r="100" fill="none" stroke="var(--con-black)" stroke-width="3" />
    <polygon points="110,10 130,110 110,210 90,110" fill="var(--con-orange)" stroke="var(--con-black)" stroke-width="2" />
    <polygon points="10,110 110,90 210,110 110,130" fill="var(--con-black)" />
    <circle cx="110" cy="110" r="14" fill="var(--con-yellow)" stroke="var(--con-black)" stroke-width="3" />
  </svg>
)}

<style>
  .con-shape {
    display: block;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
</style>
