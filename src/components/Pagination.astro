---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

function getPageNumbers(current: number, total: number): (number | string)[] {
  if (total <= 7) {
    return Array.from({ length: total }, (_, i) => i + 1);
  }
  const pages: (number | string)[] = [];
  pages.push(1);
  if (current <= 4) {
    for (let i = 2; i <= Math.min(5, total); i++) pages.push(i);
    if (total > 5) { pages.push("..."); pages.push(total); }
  } else if (current >= total - 3) {
    pages.push("...");
    for (let i = Math.max(2, total - 4); i <= total; i++) pages.push(i);
  } else {
    pages.push("...");
    for (let i = current - 1; i <= current + 1; i++) pages.push(i);
    pages.push("...");
    pages.push(total);
  }
  return pages;
}

const pageNumbers = getPageNumbers(currentPage, totalPages);

function getPageUrl(page: number): string {
  if (page === 1) return baseUrl;
  return `${baseUrl}page/${page}/`;
}
---

{totalPages > 1 && (
  <nav class="pagination" aria-label="Pagination">
    <div class="page-numbers" id="page-numbers">
      {pageNumbers.map((page) => (
        typeof page === "number" ? (
          <a
            href={getPageUrl(page)}
            class:list={["page-number", { active: page === currentPage }]}
            data-page={page}
            aria-current={page === currentPage ? "page" : undefined}
          >
            {String(page).padStart(2, "0")}
          </a>
        ) : (
          <span class="ellipsis">···</span>
        )
      ))}
    </div>

    <div class="pagination-nav">
      {currentPage > 1 && (
        <a href={getPageUrl(currentPage - 1)} class="pagination-btn prev">
          <i class="fa-sharp fa-solid fa-chevron-left"></i>
          Prev
        </a>
      )}

      {currentPage < totalPages && (
        <a href={getPageUrl(currentPage + 1)} class="pagination-btn next">
          Next
          <i class="fa-sharp fa-solid fa-chevron-right"></i>
        </a>
      )}
    </div>
  </nav>
)}

<style lang="scss">
  .pagination {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    margin-top: 36px;
    padding: 20px;
    background: var(--color-subcard-background);
    border: 2px solid var(--color-card-border);
    box-shadow: 5px 5px 0 var(--con-orange);
  }

  .pagination-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
  }

  .pagination-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: var(--con-black);
    color: var(--con-cream);
    border: 2px solid var(--color-card-border);
    text-decoration: none;
    font-family: "Oswald", sans-serif;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-size: 0.78em;
    box-shadow: 3px 3px 0 var(--con-orange);
    transition: all 0.15s ease;

    &:hover {
      background: var(--con-orange);
      color: var(--con-cream);
      transform: translate(-2px, -2px);
      box-shadow: 5px 5px 0 var(--con-black);
    }

    i { font-size: 0.85em; }
  }

  .page-numbers {
    display: flex;
    align-items: center;
    gap: 4px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .page-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 38px;
    height: 38px;
    padding: 0 6px;
    text-decoration: none;
    font-family: "Oswald", sans-serif;
    font-weight: 700;
    letter-spacing: 0.06em;
    font-size: 0.95em;
    background: var(--color-card-background);
    color: var(--color-text);
    border: 2px solid var(--color-card-border);
    transition: all 0.15s ease;

    &:hover {
      background: var(--con-yellow);
      color: var(--con-black);
    }

    &.active {
      background: var(--con-orange);
      color: var(--con-cream);
      box-shadow: 3px 3px 0 var(--color-card-border);
      transform: translate(-1px, -1px);
    }
  }

  .ellipsis {
    padding: 0 6px;
    color: var(--color-text-muted);
    font-family: "Oswald", sans-serif;
  }

  @media screen and (max-width: 600px) {
    .page-number { min-width: 34px; height: 34px; font-size: 0.85em; }
    .pagination-btn { padding: 7px 10px; font-size: 0.7em; }
  }
</style>
