---
import Layout from "@layouts/Layout.astro";

import Typer from "@components/Typer.vue";
import PagefindConfig from "astro-pagefind/components/PagefindConfig.astro";
---

<Layout
  title="Search"
  description="Search BDADAMS.com."
  sourceLink="/src/pages/search.astro"
>
  <main>
    <div class="card">
      <h1 aria-label="Search">
        <Typer client:load text="Search" duration={600} />
      </h1>

      <PagefindConfig />
      <pagefind-input autofocus placeholder="Search BDADAMS.com…"></pagefind-input>
      <pagefind-summary></pagefind-summary>
      <pagefind-results show-sub-results></pagefind-results>
    </div>
  </main>
</Layout>

<script>
  // Deep-link support: pre-fill and run a search from the `?q=` query string,
  // e.g. /search?q=astro. The v2 Pagefind components don't read the URL on
  // their own, so we drive <pagefind-input> once it has upgraded.
  function applySearchQuery() {
    const term = new URLSearchParams(location.search).get("q");
    if (!term) return;

    customElements.whenDefined("pagefind-input").then(() => {
      const el = document.querySelector<HTMLElement & { inputEl?: HTMLInputElement | null }>(
        "pagefind-input",
      );
      if (!el) return;

      const fill = (attempts = 0) => {
        const input = el.inputEl ?? el.querySelector("input");
        if (input) {
          if (input.value === term) return;
          input.value = term;
          input.dispatchEvent(new Event("input", { bubbles: true }));
        } else if (attempts < 50) {
          requestAnimationFrame(() => fill(attempts + 1));
        }
      };
      fill();
    });
  }

  document.addEventListener("astro:page-load", applySearchQuery);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", applySearchQuery);
  } else {
    applySearchQuery();
  }
</script>

