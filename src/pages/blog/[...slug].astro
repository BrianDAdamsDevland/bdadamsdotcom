---
import { Image, getImage } from "astro:assets";
import { getCollection, render } from "astro:content";

import Layout from "@layouts/Layout.astro";
import { getReadingTime } from "@utils/readingTime";

export async function getStaticPaths() {
  const blogItems = await getCollection("blog");
  return blogItems.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const openGraphImage = await getImage({
  src: entry.data.heroImage,
  width: 600,
  format: "jpg",
});
---

<Layout
  title={`${entry.data.title} | Blog`}
  description={entry.data.description}
  openGraph={{
    basic: {
      title: entry.data.title,
      type: "article",
      image: new URL(openGraphImage.src, Astro.site).href,
    },
    optional: {
      description: entry.data.description,
    },
  }}
  sourceLink="/src/pages/blog/[...slug].astro"
  contentLink={`/src/content/blog/${entry.id}`}
>
  <main>
    <div class="card">
      <a href="/blog" class="back">
        <i class="fa-sharp fa-solid fa-arrow-left-long"></i>
        Back to Dispatches
      </a>

      <div class="poster">
        <span class="stencil red filed">FILED</span>

        <div class="title">
          <h1 transition:name={`${entry.id}-title`}>{entry.data.title}</h1>
          {
            entry.data.subtitle && (
              <h2 transition:name={`${entry.id}-subtitle`}>
                {entry.data.subtitle}
              </h2>
            )
          }
        </div>

        <div class="meta">
          <span class="date-stamp" transition:name={`${entry.id}-date`}>
            {
              entry.data.pubDate.toLocaleDateString("en-us", {
                year: "numeric",
                month: "short",
                day: "2-digit",
              })
            }
          </span>
          <span class="bullet">●</span>
          <span class="reading-time">{getReadingTime(entry.body)}</span>
        </div>
      </div>

      {
        entry.data.heroImage && (
          <div class="hero duotone" transition:name={`${entry.id}-hero`}>
            <Image
              src={entry.data.heroImage}
              alt={entry.data.heroImageAltText}
              widths={[420, 600, 840, 1200]}
              sizes="(min-width: 500px) calc(100vw - 40px), calc(100vw - 20px)"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        )
      }

      <div class="content">
        <Content />
      </div>
    </div>
  </main>
</Layout>

<style lang="scss">
  .poster {
    position: relative;
    margin: 12px 0 22px;
    padding: 22px 22px 18px;
    background: var(--color-subcard-background);
    border: 2px solid var(--color-card-border);
    box-shadow: 6px 6px 0 var(--con-orange);
  }

  .filed {
    position: absolute;
    top: -12px;
    left: 14px;
    transform: rotate(-3deg);
    box-shadow: 3px 3px 0 var(--color-card-border);
  }

  .title h1 {
    margin: 12px 0 8px;
    font-size: clamp(1.8rem, 5vw, 3rem);
    line-height: 0.95;
    color: var(--color-text);
  }
  .title h2 {
    margin: 0;
    font-family: "Oswald", sans-serif;
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0.01em;
    color: var(--color-text-muted);
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    line-height: 1.2;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 14px;
    flex-wrap: wrap;
  }
  .date-stamp {
    background: var(--con-black);
    color: var(--con-cream);
    padding: 4px 10px;
    font-family: "Oswald", sans-serif;
    font-weight: 700;
    letter-spacing: 0.15em;
    font-size: 0.85em;
    border: 2px solid var(--color-card-border);
  }
  .bullet { color: var(--con-orange); }
  .reading-time {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.85em;
    color: var(--color-text-muted);
    font-style: italic;
  }

  div.hero {
    margin: 0 -10px 22px;
    border-top: 2px solid var(--color-card-border);
    border-bottom: 2px solid var(--color-card-border);
    background: var(--con-orange);
    line-height: 0;
  }
  div.hero img {
    max-width: 100%;
    height: auto;
    display: block;
    filter: contrast(1.08) saturate(0.92);
  }

  .content {
    font-size: 1.08em;
    font-family: "IBM Plex Sans", sans-serif;
    line-height: 1.7;
  }

  .content :global(p) {
    margin-bottom: 22px;
    overflow-wrap: break-word;
  }
  .content :global(h2),
  .content :global(h3),
  .content :global(h4) {
    margin-top: 32px;
    margin-bottom: 12px;
    border-left: 5px solid var(--con-orange);
    padding-left: 12px;
  }
  .content :global(h2) { font-size: 1.5em; }
  .content :global(h3) { font-size: 1.25em; color: var(--color-text); }
  .content :global(h4) { font-size: 1.05em; color: var(--color-text-muted); }

  .content :global(li) { margin-bottom: 8px; }
  .content :global(pre) {
    padding: 16px;
    background: var(--color-background-dark) !important;
    border: 2px solid var(--color-card-border);
    box-shadow: 4px 4px 0 var(--con-orange);
    overflow-x: auto;
  }
  .content :global(code) {
    font-size: 0.92em;
  }
  .content :global(p code),
  .content :global(li code) {
    background: var(--color-subcard-background);
    padding: 1px 6px;
    border: 1px solid var(--color-card-border);
  }

  .content :global(img) {
    width: 100%;
    max-width: 600px;
    display: block;
    height: auto;
    border: 2px solid var(--color-card-border);
    box-shadow: 5px 5px 0 var(--con-orange);

    &.center { margin: 0 auto; }
    &.large { max-width: 720px; }
    &.small { max-width: 400px; }
    &.extra-small { max-width: 220px; }
  }

  .content :global(figcaption) {
    font-size: 0.85em;
    color: var(--color-text-muted);
    font-style: italic;
    margin-top: 6px;

    &.center { text-align: center; }
  }

  .content :global(blockquote) {
    font-size: 1.1em;
    font-weight: 500;
    background: var(--con-orange);
    color: var(--con-cream);
    padding: 18px 20px;
    margin: 24px 0;
    border: 2px solid var(--color-card-border);
    box-shadow: 5px 5px 0 var(--color-card-border);
    position: relative;
  }
  .content :global(blockquote::before) {
    content: "❝";
    position: absolute;
    top: -16px;
    left: 12px;
    background: var(--con-cream);
    color: var(--con-orange);
    padding: 0 10px;
    font-size: 1.6em;
    line-height: 1;
    border: 2px solid var(--color-card-border);
    font-weight: 700;
  }
  .content :global(blockquote p:first-child) { margin-top: 0; }
  .content :global(blockquote p:last-child) { margin-bottom: 0; }
  .content :global(blockquote a) { color: var(--con-cream); border-bottom: 2px solid var(--con-cream); text-decoration: none; }

  @media screen and (min-width: 500px) {
    div.hero {
      margin-left: -20px;
      margin-right: -20px;
    }
  }
</style>
