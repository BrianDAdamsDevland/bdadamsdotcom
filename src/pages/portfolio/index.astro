---
import { Image } from "astro:assets";

import Layout from "@layouts/Layout.astro";
import Typer from "@components/Typer.vue";

import { getCollection } from "astro:content";
import Enumerable from "linq";

const allPortfolioCollection = await getCollection("portfolio");

const portfolioItems = Enumerable.from(allPortfolioCollection)
  .select((i) => ({ ...i.data, slug: i.id }))
  .orderByDescending((a) => a.year)
  .toArray();
---

<Layout
  title="Portfolio"
  description="Brian D. Adams portfolio of past application work."
  sourceLink="/src/pages/portfolio/index.astro"
>
  <main>
    <div class="card">
      <header class="page-head">
        <span class="big-mark" aria-hidden="true">П</span>
        <span class="stencil red">CATALOGUE / КАТАЛОГ</span>
        <h1>
          <Typer client:load text="Portfolio" duration={700} />
        </h1>
        <p class="lede">Selected works · {portfolioItems.length} entries · arranged by year, descending.</p>
      </header>

      <div class="hatch-divider"></div>

      <div class="portfolio-grid">
        {
          portfolioItems.map((item, i) => (
            <article class:list={["item", { feature: i === 0 }]}>
              <a class="item-img" href={`/portfolio/${item.slug}/`}>
                <div class="item-img-frame duotone">
                  <Image
                    src={item.image}
                    alt={item.title}
                    widths={[240, 370, 540, 720, 800, item.image.width]}
                    sizes="(min-width: 900px) 370px, (min-width: 500px) calc(50vw - 53px), calc(50vw - 33px)"
                    transition:name={`${item.slug}-img`}
                    decoding="async"
                    loading={i < 6 ? "eager" : "lazy"}
                    fetchpriority={i < 3 ? "high" : undefined}
                  />
                </div>
                <span class="year-stamp" transition:name={`${item.slug}-year`}>{item.year}</span>
                <span class="index-num">{String(i + 1).padStart(2, "0")}</span>
              </a>

              <a href={`/portfolio/${item.slug}/`} class="item-title">
                <strong transition:name={`${item.slug}-title`}>{item.title}</strong>
                <span class="view">View →</span>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </main>
</Layout>

<style lang="scss">
  main {
    max-width: 1240px;
  }

  .page-head {
    margin-bottom: 8px;
  }
  .page-head h1 { margin: 10px 0 6px; }
  .lede {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.95em;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 22px;
  }

  .item {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .item-img {
    position: relative;
    text-decoration: none;
    display: block;
    transition: transform 0.2s ease;
  }
  .item-img:hover { transform: translate(-2px, -2px); }

  .item-img-frame {
    border: 2px solid var(--color-card-border);
    background: var(--con-orange);
    overflow: hidden;
    box-shadow: 6px 6px 0 var(--color-card-border);
    transition: box-shadow 0.2s ease;
    aspect-ratio: 1;
    line-height: 0;
  }
  .item-img:hover .item-img-frame {
    box-shadow: 8px 8px 0 var(--con-orange), 8px 8px 0 1px var(--color-card-border);
  }
  .item-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 10%;
    display: block;
    filter: contrast(1.08) saturate(0.9);
  }

  .year-stamp {
    position: absolute;
    bottom: -12px;
    right: 10px;
    background: var(--con-black);
    color: var(--con-cream);
    font-family: "Oswald", sans-serif;
    font-weight: 700;
    padding: 4px 10px;
    border: 2px solid var(--color-card-border);
    letter-spacing: 0.15em;
    font-size: 0.85em;
  }

  .index-num {
    position: absolute;
    top: -10px;
    left: -10px;
    background: var(--con-orange);
    color: var(--con-cream);
    font-family: "Oswald", sans-serif;
    font-weight: 700;
    padding: 2px 8px;
    border: 2px solid var(--color-card-border);
    font-size: 0.8em;
    letter-spacing: 0.1em;
  }

  .item-title {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    text-decoration: none;
    color: var(--color-text);
    padding-top: 4px;
    font-family: "Oswald", sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .item-title strong {
    font-weight: 700;
    font-size: 1.05em;
    line-height: 1.2;
  }
  .item-title .view {
    font-size: 0.7em;
    color: var(--con-orange);
    letter-spacing: 0.2em;
    white-space: nowrap;
  }

  /* Feature item — make first one big */
  @media screen and (min-width: 900px) {
    .portfolio-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .item.feature {
      grid-column: span 2;
      grid-row: span 2;
    }
    .item.feature .item-title strong {
      font-size: 1.5em;
    }
  }

  @media screen and (max-width: 500px) {
    .portfolio-grid { gap: 18px; }
    .item-title strong { font-size: 0.95em; }
  }
</style>
